# =========================
# KYvC AndroidApp Env Example
# =========================
# 참고:
# - 현재 Android 앱은 아래 값을 자동으로 읽지 않습니다.
# - 팀 공통 설정 공유/문서화를 위한 예시 파일입니다.
# - 실제 값은 앱 상수(MainActivity) 또는 웹 입력 필드(coreBaseUrl 등)에 반영해서 사용합니다.

# WebView start URL
WEBVIEW_PRIMARY_URL=https://dev-kyvc.khuoo.synology.me/m/
WEBVIEW_FALLBACK_URL=file:///android_asset/index.html

# Core / Verifier endpoints
CORE_BASE_URL=https://dev-core-kyvc.khuoo.synology.me
VERIFIER_VERIFY_ENDPOINT=https://dev-core-kyvc.khuoo.synology.me/verifier/presentations/verify
VERIFIER_CHALLENGE_ENDPOINT=https://dev-core-kyvc.khuoo.synology.me/verifier/presentations/challenges

# XRPL network mode (for team convention/docs)
XRPL_NETWORK=testnet

# Optional timeouts (team convention/docs)
HTTP_CONNECT_TIMEOUT_MS=20000
HTTP_READ_TIMEOUT_MS=60000
HTTP_WRITE_TIMEOUT_MS=30000
HTTP_CALL_TIMEOUT_MS=75000

